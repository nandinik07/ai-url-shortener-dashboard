PORT=5000
NODE_ENV=development

# Frontend URL (for CORS config)
FRONTEND_URL=http://localhost:5173

# Gemini API Key for AI suggestions
GEMINI_API_KEY=your_gemini_api_key_here

# Database configuration
# The backend will automatically fall back to a local SQLite database if PostgreSQL is unreachable.
# Set USE_SQLITE=true to force SQLite
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shortener
USE_SQLITE=false

# Cache configuration
# The backend will automatically fall back to an in-memory Map cache if Redis is unreachable.
# Set USE_MEMORY_CACHE=true to force in-memory cache
REDIS_URL=redis://localhost:6379
USE_MEMORY_CACHE=false
