PORT=5000
NODE_ENV=development

# Frontend URL (for CORS config)
FRONTEND_URL=http://localhost:5173

# Gemini API Key for AI suggestions (leave empty to fallback to programmatic SEO generation)
GEMINI_API_KEY=

# Database configuration
# The backend will automatically fall back to a local SQLite database (database.sqlite) if PostgreSQL is unreachable.
# To force SQLite local database, set USE_SQLITE=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shortener
USE_SQLITE=true

# Cache configuration
# The backend will automatically fall back to an in-memory Map cache if Redis is unreachable.
# To force in-memory cache, set USE_MEMORY_CACHE=true
REDIS_URL=redis://localhost:6379
USE_MEMORY_CACHE=true
